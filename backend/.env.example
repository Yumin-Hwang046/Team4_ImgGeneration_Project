# OpenAI API 키 (GPT Vision — 이미지 분석 + 카피라이팅)
OPENAI_API_KEY=sk-...

# 사용할 OpenAI 텍스트 모델
OPENAI_MODEL=gpt-4o-mini

# 이미지 생성 모델 선택 (로컬 diffusers — API 키 불필요)
# sdxl-lightning : ByteDance/SDXL-Lightning  (권장, 4스텝, VRAM 8GB+)
# sdxl           : stabilityai/sdxl-base-1.0 (고품질, VRAM 10GB+)
# flux-schnell   : black-forest-labs/FLUX.1-schnell (최고품질, VRAM 12GB+)
IMAGE_MODEL=sdxl-lightning

# IP-Adapter 설정 (스타일 레퍼런스 이미지 사용 시)
IP_ADAPTER_ENABLED=true
IP_ADAPTER_SCALE=0.6
IP_ADAPTER_WEIGHT=ip-adapter_sdxl.safetensors

# LoRA 경로 (선택, 콤마로 여러 개 지정 가능)
# LORA_PATHS=/path/to/lora.safetensors:0.7,/path/to/lora2.safetensors:0.5

# 한국어 폰트 경로 (Windows Malgun Gothic 자동 감지, 없을 경우 지정)
# KOREAN_FONT_PATH=/path/to/NanumGothic.ttf
